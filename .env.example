# ─────────────────────────────────────────────────────────
# PixelMind 后端服务 — 环境变量配置模板
# 复制本文件为 .env 后填写实际值，切勿提交 .env 到 Git
# ─────────────────────────────────────────────────────────

# ── 应用 ────────────────────────────────────────────────
APP_ENV=development              # development | production
APP_NAME=PixelMind
APP_VERSION=1.0.0
DEBUG=true
PORT=8000

# ── 安全 ────────────────────────────────────────────────
# 使用 openssl rand -hex 32 生成
JWT_SECRET_KEY=your-super-secret-jwt-key-here-change-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_HOURS=2
REFRESH_TOKEN_EXPIRE_DAYS=30

# ── 数据库 ─────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://pixelmind:password@localhost:5432/pixelmind
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=10

# ── Redis ─────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
REDIS_MAX_CONNECTIONS=50

# ── Celery ─────────────────────────────────────────────
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# ── CORS ───────────────────────────────────────────────
# 逗号分隔多个域名
ALLOWED_ORIGINS=http://localhost:3000,https://pixelmind.app,https://www.pixelmind.app

# ── AI 模型 ─────────────────────────────────────────────
OPENAI_API_KEY=sk-...
DASHSCOPE_API_KEY=sk-...          # 通义万相
STABILITY_API_KEY=sk-...          # Stability AI

# ── Cloudflare R2 ──────────────────────────────────────
R2_ACCOUNT_ID=your-account-id
R2_ACCESS_KEY_ID=your-access-key
R2_SECRET_ACCESS_KEY=your-secret-key
R2_BUCKET_NAME=pixelmind-assets
R2_PUBLIC_DOMAIN=https://assets.pixelmind.app

# ── 微信支付 ────────────────────────────────────────────
WECHAT_PAY_MCH_ID=your-mch-id
WECHAT_PAY_APP_ID=your-app-id
WECHAT_PAY_API_V3_KEY=your-api-v3-key
WECHAT_PAY_PRIVATE_KEY_PATH=/etc/pixelmind/wechat_pay_private_key.pem
WECHAT_PAY_CERT_SERIAL=your-cert-serial-no

# ── Stripe ─────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# ── 微信 OAuth ──────────────────────────────────────────
WECHAT_OAUTH_APP_ID=your-wechat-appid
WECHAT_OAUTH_APP_SECRET=your-wechat-appsecret
WECHAT_OAUTH_REDIRECT_URI=https://pixelmind.app/api/v1/auth/oauth/wechat/callback

# ── Google OAuth ────────────────────────────────────────
GOOGLE_OAUTH_CLIENT_ID=your-google-client-id
GOOGLE_OAUTH_CLIENT_SECRET=your-google-client-secret
GOOGLE_OAUTH_REDIRECT_URI=https://pixelmind.app/api/v1/auth/oauth/google/callback

# ── 邮件（SMTP）───────────────────────────────────────
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USERNAME=noreply@pixelmind.app
SMTP_PASSWORD=your-smtp-password
SMTP_FROM=PixelMind <noreply@pixelmind.app>

# ── 短信（腾讯云）──────────────────────────────────────
TENCENT_SMS_SECRET_ID=your-secret-id
TENCENT_SMS_SECRET_KEY=your-secret-key
TENCENT_SMS_APP_ID=your-app-id
TENCENT_SMS_SIGN=PixelMind

# ── Sentry ─────────────────────────────────────────────
SENTRY_DSN=https://...@sentry.io/...

# ── 日志 ───────────────────────────────────────────────
LOG_LEVEL=INFO                   # DEBUG | INFO | WARNING | ERROR
