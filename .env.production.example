# 生产环境配置示例
# 复制到 .env.production 并填入实际的敏感信息

# ========== 数据库配置 ==========
DB_USER=postgres
DB_PASSWORD=your-secure-password-here  # 改为强密码
DB_NAME=pixel_db
DB_HOST=postgres
DB_PORT=5432

# ========== Redis 配置 ==========
REDIS_URL=redis://redis:6379/0

# ========== 应用配置 ==========
ENVIRONMENT=production
DEBUG=false
LOG_LEVEL=info
SECRET_KEY=your-secret-key-here-change-this  # 改为随机的强密钥

# ========== Cloudflare R2（对象存储）==========
# 在 Cloudflare 控制面板获取
AWS_ACCESS_KEY_ID=your-cloudflare-access-key
AWS_SECRET_ACCESS_KEY=your-cloudflare-secret-key
AWS_S3_BUCKET=pixel-assets  # 你的 R2 bucket 名称
AWS_S3_REGION=auto  # Cloudflare R2 用 auto
AWS_S3_ENDPOINT_URL=https://your-account-id.r2.cloudflarestorage.com  # 替换你的 account ID

# ========== AI 模型 API 密钥 ==========
# OpenAI DALL-E
OPENAI_API_KEY=sk-your-openai-key-here

# 通义万相（阿里云）
DASHSCOPE_API_KEY=sk-your-dashscope-key-here

# Stability AI
STABILITY_API_KEY=sk-your-stability-key-here

# ========== 支付配置 ==========
# Stripe
STRIPE_API_KEY=sk_live_your-stripe-key-here
STRIPE_WEBHOOK_SECRET=whsec_your-webhook-secret

# 微信支付 V3
WECHAT_PAY_MERCHANT_ID=your-merchant-id
WECHAT_PAY_API_KEY=your-api-key
WECHAT_PAY_CERT_SERIAL_NO=your-cert-serial
WECHAT_PAY_PRIVATE_KEY_PATH=/app/config/wechat_pay_key.pem

# ========== OAuth 配置 ==========
# Google OAuth
GOOGLE_OAUTH_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_OAUTH_CLIENT_SECRET=your-google-client-secret
GOOGLE_OAUTH_REDIRECT_URI=https://118.25.22.37/api/v1/auth/google/callback

# 微信 OAuth
WECHAT_OAUTH_APPID=your-wechat-appid
WECHAT_OAUTH_SECRET=your-wechat-secret
WECHAT_OAUTH_REDIRECT_URI=https://118.25.22.37/api/v1/auth/wechat/callback

# ========== 监控和错误追踪 ==========
# Sentry（错误追踪）
SENTRY_DSN=https://your-sentry-key@sentry.io/your-project-id

# Prometheus（可选，指标收集）
PROMETHEUS_ENABLED=false
PROMETHEUS_PORT=9090

# ========== 邮件配置（用于通知） ==========
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SENDER_EMAIL=noreply@pixel.ai

# ========== 域名配置 ==========
DOMAIN=118.25.22.37  # 改为你的域名
CORS_ORIGINS=https://your-frontend-domain.com

# ========== Celery 配置 ==========
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1
CELERY_TASK_SERIALIZER=json
CELERY_RESULT_SERIALIZER=json
CELERY_ACCEPT_CONTENT=json
CELERY_TASK_TIME_LIMIT=3600  # 1 小时
CELERY_TASK_SOFT_TIME_LIMIT=3300  # 55 分钟
